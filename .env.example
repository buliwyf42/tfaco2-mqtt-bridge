MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=your_user
MQTT_PASS=your_password

# Optional
MQTT_TOPIC_PREFIX=CO2
HA_PREFIX=homeassistant
HA_DISCOVERY_ENABLED=true
DEVICE_ID=co2meter_tfaco2
DEVICE_NAME=TFA CO2 Meter
DEVICE_MODEL=TFACO2 AirCO2ntrol
DEVICE_MANUFACTURER=TFA
MQTT_CLIENT_ID=co2meter_tfaco2-bridge
MQTT_KEEPALIVE=60
DEVICE_PATH=/dev/hidraw0

# Retry timing (optional, defaults shown)
#DEVICE_RETRY_DELAY_SECONDS=5
#MQTT_CONNECT_RETRY_SECONDS=5

# TLS (optional, disabled by default)
# Set MQTT_TLS_ENABLED=true and MQTT_PORT=8883 to enable TLS.
# Set MQTT_TLS_INSECURE=true to encrypt without verifying the broker certificate.
# Provide MQTT_TLS_CA_CERT for a custom CA (self-signed broker).
# Provide MQTT_TLS_CERTFILE and MQTT_TLS_KEYFILE for mutual TLS.
#MQTT_TLS_ENABLED=false
#MQTT_TLS_INSECURE=false
#MQTT_TLS_CA_CERT=/certs/ca.crt
#MQTT_TLS_CERTFILE=/certs/client.crt
#MQTT_TLS_KEYFILE=/certs/client.key
